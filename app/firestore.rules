rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function projectPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function ownsProject(projectId) {
      return isSignedIn() && get(projectPath(projectId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow read, delete: if ownsProject(projectId);

      allow update: if ownsProject(projectId)
                    && request.resource.data.userId == resource.data.userId;

      match /outputs/{outputId} {
        allow create: if ownsProject(projectId)
                      && request.resource.data.userId == request.auth.uid;

        allow read, delete: if ownsProject(projectId)
                            && resource.data.userId == request.auth.uid;

        allow update: if ownsProject(projectId)
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == resource.data.userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
