# Stripe Configuration
# 1. Create a Stripe account at https://stripe.com
# 2. Create a product "ShopLogic" with price $29
# 3. Get your publishable key from https://dashboard.stripe.com/apikeys
# 4. Create a hosted checkout link from the product page
# 5. Fill in the values below

VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_ID=price_...
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/...

# Firebase Configuration
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Enable Firestore Database (Start in production mode)
# 3. Enable Email/Password Authentication
# 4. Go to Project Settings → Your apps → Web
# 5. Copy the Firebase config values below

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=shoplogic-xxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shoplogic-xxx
VITE_FIREBASE_STORAGE_BUCKET=shoplogic-xxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456...
VITE_FIREBASE_APP_ID=1:123456...
